---
/**
 * Server-rendered wrapper for HeroCarousel.vue.
 *
 * Takes the home page's featured project entries, runs each cover image
 * through Astro's image pipeline at hero-friendly widths, and hands the
 * pre-optimised URLs to the Vue carousel (which only takes over for
 * pagination + autoplay logic). The first slide ships eager + high
 * fetchpriority for LCP; the rest are lazy.
 */
import { getImage } from "astro:assets";
import HeroCarouselClient from "./HeroCarousel.vue";

interface FeaturedSlide {
  title: string;
  location: string;
  href: string;
  cover: ImageMetadata;
}

interface Props {
  slides: FeaturedSlide[];
  intervalMs?: number;
}

const { slides, intervalMs = 6000 } = Astro.props;

const optimised = await Promise.all(
  slides.map(async (s) => {
    const img = await getImage({
      src: s.cover,
      widths: [800, 1200, 1600, 2000, 2400],
      sizes: "100vw",
      format: "webp",
      quality: 78,
    });
    return {
      src: img.src,
      srcset: img.srcSet?.attribute ?? undefined,
      width: img.attributes.width ?? s.cover.width,
      height: img.attributes.height ?? s.cover.height,
      alt: `${s.title} — ${s.location}`,
      title: s.title,
      location: s.location,
      href: s.href,
    };
  })
);
---

<HeroCarouselClient client:load slides={optimised} intervalMs={intervalMs} />
