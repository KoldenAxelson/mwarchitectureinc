---
/**
 * Server-rendered wrapper for HeroCarousel.vue.
 *
 * For each featured project we ask Astro's image pipeline for both an
 * AVIF and a WebP variant set. The carousel renders a <picture> with
 * <source type="image/avif"> first, falling back to WebP, falling back
 * to the WebP <img>'s direct src for any browser that ignores both.
 * AVIF lands ~30% smaller than WebP for these renderings, which buys
 * us LCP headroom on the home page hero.
 *
 * The first slide is eager + fetchpriority="high" — and on the home
 * page we additionally emit a <link rel="preload"> via the layout's
 * head slot to start the fetch before the parser reaches the <img>.
 */
import { getImage } from "astro:assets";
import HeroCarouselClient from "./HeroCarousel.vue";

interface FeaturedSlide {
  title: string;
  location: string;
  href: string;
  cover: ImageMetadata;
}

interface Props {
  slides: FeaturedSlide[];
  intervalMs?: number;
}

const { slides, intervalMs = 6000 } = Astro.props;

const HERO_WIDTHS = [800, 1200, 1600, 2000, 2400];
const HERO_SIZES = "100vw";

const optimised = await Promise.all(
  slides.map(async (s) => {
    const [avif, webp] = await Promise.all([
      getImage({
        src: s.cover,
        widths: HERO_WIDTHS,
        sizes: HERO_SIZES,
        format: "avif",
        quality: 60,
      }),
      getImage({
        src: s.cover,
        widths: HERO_WIDTHS,
        sizes: HERO_SIZES,
        format: "webp",
        quality: 78,
      }),
    ]);
    return {
      avifSrcset: avif.srcSet?.attribute ?? undefined,
      webpSrcset: webp.srcSet?.attribute ?? undefined,
      // <img> fallback — the WebP single src for any browser that
      // ignores both <source> elements (very rare in 2026).
      src: webp.src,
      width: webp.attributes.width ?? s.cover.width,
      height: webp.attributes.height ?? s.cover.height,
      alt: `${s.title} — ${s.location}`,
      title: s.title,
      location: s.location,
      href: s.href,
    };
  })
);
---

<HeroCarouselClient
  client:load
  slides={optimised}
  intervalMs={intervalMs}
/>
