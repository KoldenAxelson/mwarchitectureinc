---
import "~/styles/global.css";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { getImage } from "astro:assets";
import logo from "~/assets/logo.png";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "MW Architecture — Residential, commercial, and multi-family architecture in Solvang, Santa Ynez Valley, and the Central Coast.",
  ogImage,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteName = "MW Architecture";
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL("/og-default.jpg", Astro.site).toString();

// Favicon variants — generated from /src/assets/logo.png at build time so
// the URL changes whenever the logo changes, naturally cache-busting the
// browser's aggressive favicon cache. Astro dedupes these calls across
// the whole build, so emitting them per-page is free.
const [favicon32, favicon192, appleTouch] = await Promise.all([
  getImage({ src: logo, width: 32, height: 32, format: "png" }),
  getImage({ src: logo, width: 192, height: 192, format: "png" }),
  getImage({ src: logo, width: 180, height: 180, format: "png" }),
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={`${title} — ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon set, generated from the brand emblem at build time. -->
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={favicon32.src}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={favicon192.src}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={appleTouch.src}
    />
    <meta name="theme-color" content="#edeee9" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Per-page resource hints (e.g. hero image preload on /). Pages
         opt in via <Fragment slot="head"> so we don't block rendering
         on hints that aren't relevant. -->
    <slot name="head" />
  </head>

  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-near-black focus:text-off-white focus:px-3 focus:py-2"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      import "~/scripts/reveal.client.ts";
    </script>
  </body>
</html>
