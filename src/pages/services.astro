---
export const prerender = true;

import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ServiceBlock from "~/components/ServiceBlock.vue";

// Each example is { label, slug } where slug matches a file under
// src/content/projects/<slug>.mdx — kept as data so the JSX template
// can map them straight into <a href="/portfolio/{slug}">.
const services = [
  {
    title: "Residential Architecture",
    blurb:
      "Intimate expression of individual lifestyle and identity. Practicality and functionality shaped by the distinct needs and visions of each user — from new ground-up homes to thoughtful renovations.",
    examples: [
      { label: "Montecito Estate", slug: "montecito-estate" },
      { label: "Voog Residence", slug: "voog-residence" },
      { label: "Schluep Residence", slug: "schluep-residence" },
    ],
  },
  {
    title: "Commercial Spaces",
    blurb:
      "A balance between functionality, aesthetics, and user experience. Spaces that inspire and engage employees and guests while remaining sustainable, efficient, and grounded in their place.",
    examples: [
      { label: "Central Coast Jet Center", slug: "central-coast-jet-center" },
      { label: "SYV Winery", slug: "syv-winery" },
      { label: "Goodstuff Farms", slug: "goodstuff-farms-winery" },
    ],
  },
  {
    title: "Multi-family Developments",
    blurb:
      "Fostering community while addressing individual needs. The integration of public and private spaces, blurring boundaries to encourage connectivity without sacrificing dignity or privacy.",
    examples: [
      { label: "Good Land Apartments", slug: "good-land-apartments" },
      { label: "J Street Mixed-Use", slug: "j-street-mixed-use-development" },
      { label: "The Edge", slug: "the-edge" },
    ],
  },
];

// Pull every project once, key by slug so the lookups below are O(1).
const projects = await getCollection("projects");
const projectsBySlug = new Map(projects.map((p) => [p.id, p]));

// Resolve each service's example list to optimised slide data we can
// hand straight to the Vue carousel component (no further image work
// happens client-side).
const servicesWithSlides = await Promise.all(
  services.map(async (s) => {
    const slides = await Promise.all(
      s.examples.map(async (ex) => {
        const project = projectsBySlug.get(ex.slug);
        if (!project) {
          throw new Error(
            `Services page references unknown project slug: ${ex.slug}`
          );
        }
        const img = await getImage({
          src: project.data.coverImage,
          widths: [400, 600, 900, 1200],
          sizes: "(min-width: 1024px) 33vw, 100vw",
          format: "webp",
          quality: 78,
        });
        return {
          slug: ex.slug,
          label: ex.label,
          src: img.src,
          srcset: img.srcSet?.attribute ?? undefined,
          width: img.attributes.width ?? project.data.coverImage.width,
          height: img.attributes.height ?? project.data.coverImage.height,
          alt: `${project.data.title} — ${project.data.location}`,
        };
      })
    );
    return { ...s, slides };
  })
);
---

<BaseLayout
  title="Services"
  description="Residential, commercial, and multi-family architecture services from MW Architecture in Solvang, CA."
>
  <section class="mx-auto max-w-7xl px-6 sm:px-8 pt-16 pb-12">
    <p
      class="text-xs uppercase tracking-[0.22em] text-mid-grey"
      data-reveal="up"
    >
      Services
    </p>
    <h1
      class="mt-3 text-3xl sm:text-5xl max-w-3xl"
      data-reveal="up"
      data-reveal-delay="120"
    >
      Three practices, one studio.
    </h1>
    <p
      class="mt-6 max-w-2xl text-body/85"
      data-reveal="up"
      data-reveal-delay="240"
    >
      We design at every scale — from a single residence to mixed-use districts —
      always rooted in place, climate, and the people who will use the space.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 sm:px-8 pb-24">
    <ul class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">
      {
        servicesWithSlides.map((s) => (
          <ServiceBlock
            client:visible
            title={s.title}
            blurb={s.blurb}
            slides={s.slides}
          />
        ))
      }
    </ul>
  </section>
</BaseLayout>
