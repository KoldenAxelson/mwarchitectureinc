---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("projects", ({ data }) => !data.draft);

// Order: explicit `order` first (asc), then date (desc).
const projects = all.sort((a, b) => {
  const ao = a.data.order ?? Number.POSITIVE_INFINITY;
  const bo = b.data.order ?? Number.POSITIVE_INFINITY;
  if (ao !== bo) return ao - bo;
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<BaseLayout
  title="Portfolio"
  description="Selected residential, commercial, and multi-family projects by MW Architecture across Santa Barbara County and the Central Coast."
>
  <section class="mx-auto max-w-7xl px-6 sm:px-8 pt-16 pb-12">
    <p
      class="text-xs uppercase tracking-[0.22em] text-mid-grey"
      data-reveal="up"
    >
      Portfolio
    </p>
    <h1
      class="mt-3 text-3xl sm:text-5xl max-w-3xl"
      data-reveal="up"
      data-reveal-delay="120"
    >
      Selected work
    </h1>
    <p
      class="mt-6 max-w-2xl text-body/85"
      data-reveal="up"
      data-reveal-delay="240"
    >
      A range of residential, commercial, and multi-family projects across the
      Central Coast — built and underway.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 sm:px-8 pb-24">
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-14">
      {
        projects.map((p, i) => (
          <li
            data-reveal="up"
            data-reveal-delay={(i % 3) * 120}
          >
            <a
              href={`/portfolio/${p.id}`}
              class="group block focus:outline-none"
              aria-label={`View ${p.data.title}`}
            >
              <div class="aspect-[4/3] overflow-hidden bg-warm-grey/20">
                <Image
                  src={p.data.coverImage}
                  alt={`${p.data.title} — ${p.data.location}`}
                  widths={[400, 700, 1000]}
                  sizes="(min-width: 1024px) 380px, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  class="size-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                />
              </div>
              <div class="mt-5">
                <h2 class="text-lg font-semibold text-near-black group-hover:text-terracotta transition-colors">
                  {p.data.title}
                </h2>
                <p class="mt-1 text-[11px] uppercase tracking-[0.16em] text-mid-grey">
                  {p.data.location}
                </p>
              </div>
              {p.data.summary && (
                <p class="mt-2 text-sm text-body/80 line-clamp-2">
                  {p.data.summary}
                </p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
