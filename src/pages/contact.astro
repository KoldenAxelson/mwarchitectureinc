---
export const prerender = true;

import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ContactForm from "~/components/ContactForm.vue";
import IconPhone from "~/components/icons/IconPhone.astro";
import IconEnvelope from "~/components/icons/IconEnvelope.astro";
import moritzPhoto from "~/assets/principals/moritz.jpg";
import wadePhoto from "~/assets/principals/wade.jpg";

/**
 * Contact page modeled after the existing site's home contact section:
 * intro at top, principal cards stacked on the left, form on the right.
 */
const principals = [
  {
    name: "Wade Mously",
    role: "Principal Architect",
    phone: "818-414-7101",
    phoneHref: "tel:+18184147101",
    email: "wade@mwarchitectureinc.com",
    photo: wadePhoto,
  },
  {
    name: "Moritz Willen",
    role: "Principal Architect",
    phone: "805-448-2611",
    phoneHref: "tel:+18054482611",
    email: "moritz@mwarchitectureinc.com",
    photo: moritzPhoto,
  },
];
---

<BaseLayout
  title="Contact"
  description="Reach out to MW Architecture about your residential, commercial, or multi-family project on the Central Coast."
>
  <!-- Heading + intro -->
  <section class="mx-auto max-w-7xl px-6 sm:px-8 pt-16 pb-10">
    <p
      class="text-xs uppercase tracking-[0.22em] text-mid-grey"
      data-reveal="up"
    >
      Get In Touch
    </p>
    <h1
      class="mt-3 text-3xl sm:text-5xl max-w-3xl"
      data-reveal="up"
      data-reveal-delay="120"
    >
      Let&rsquo;s discuss your project.
    </h1>
    <p
      class="mt-6 max-w-2xl text-body/85 sm:text-lg leading-relaxed"
      data-reveal="up"
      data-reveal-delay="240"
    >
      We&rsquo;d love to discuss your project and explore how we can bring your
      ideas to life. Reach out directly to either of us, or send a note through
      the form — we&rsquo;ll be in touch within a few business days.
    </p>
  </section>

  <!-- Two-column: principals stacked on left, form on right -->
  <section class="mx-auto max-w-7xl px-6 sm:px-8 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- LEFT — principal cards, stacked -->
      <aside class="lg:col-span-2 space-y-8">
        {
          principals.map((p, i) => (
            <article
              class="flex items-start gap-5"
              data-reveal="up"
              data-reveal-delay={i * 140}
            >
              <div
                class="size-24 sm:size-28 shrink-0 overflow-hidden rounded-lg bg-warm-grey/15 ring-1 ring-warm-grey/50 shadow-xl shadow-near-black/30"
              >
                <Image
                  src={p.photo}
                  alt={`${p.name} — ${p.role}, MW Architecture`}
                  widths={[200, 320]}
                  sizes="120px"
                  loading="lazy"
                  class="size-full object-cover"
                />
              </div>

              <div class="min-w-0 flex-1">
                <h2 class="text-lg text-near-black leading-tight">
                  {p.name}
                </h2>
                <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-mid-grey">
                  {p.role}
                </p>
                <dl class="mt-3 space-y-1.5 text-sm">
                  <div class="flex items-center gap-2.5">
                    <dt class="text-mid-grey">
                      <IconPhone label="Phone" />
                    </dt>
                    <dd>
                      <a
                        href={p.phoneHref}
                        class="font-display font-medium tracking-wide hover:text-terracotta transition-colors"
                      >
                        {p.phone}
                      </a>
                    </dd>
                  </div>
                  <div class="flex items-center gap-2.5">
                    <dt class="text-mid-grey">
                      <IconEnvelope label="Email" />
                    </dt>
                    <dd class="min-w-0">
                      <a
                        href={`mailto:${p.email}`}
                        class="font-display font-medium tracking-wide hover:text-terracotta transition-colors break-all"
                      >
                        {p.email}
                      </a>
                    </dd>
                  </div>
                </dl>
              </div>
            </article>
          ))
        }
      </aside>

      <!-- RIGHT — form -->
      <div
        class="lg:col-span-3 lg:border-l lg:border-warm-grey/40 lg:pl-12 xl:pl-16"
        data-reveal="up"
        data-reveal-delay="200"
      >
        <p class="text-xs uppercase tracking-[0.22em] text-mid-grey">
          Contact Our Studio
        </p>
        <h2 class="mt-3 text-2xl sm:text-3xl text-near-black">
          Send us a message
        </h2>
        <p class="mt-3 text-body/80">
          Tell us a bit about what you have in mind and we&rsquo;ll route your
          note to the right person.
        </p>
        <div class="mt-8">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
