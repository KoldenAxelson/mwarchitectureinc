---
export const prerender = true;

import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroCarousel from "~/components/HeroCarousel.astro";

// Featured strip on the home page = first three projects by `order`.
const all = await getCollection("projects", ({ data }) => !data.draft);
const sorted = all.sort((a, b) => {
  const ao = a.data.order ?? Number.POSITIVE_INFINITY;
  const bo = b.data.order ?? Number.POSITIVE_INFINITY;
  return ao - bo;
});
const featured = sorted.slice(0, 3);

// Hero carousel rotates through the same featured projects so it
// stays in sync with the strip below.
const heroSlides = featured.map((p) => ({
  title: p.data.title,
  location: p.data.location,
  href: `/portfolio/${p.id}`,
  cover: p.data.coverImage,
}));

// Preload the FIRST hero slide so the browser starts fetching it
// before the parser reaches the <img>. Uses WebP for universal modern
// support (AVIF fallback inside the carousel still applies for the
// actual render). Saves ~150–300ms on cold-load LCP.
const heroPreload =
  featured.length > 0
    ? await getImage({
        src: featured[0].data.coverImage,
        widths: [800, 1200, 1600, 2000, 2400],
        sizes: "100vw",
        format: "webp",
        quality: 78,
      })
    : null;
---

<BaseLayout
  title="Architecture for the Central Coast"
  description="MW Architecture, Inc. — residential, commercial, and multi-family architecture rooted in Solvang and the Santa Ynez Valley."
>
  {
    heroPreload && (
      <Fragment slot="head">
        <link
          rel="preload"
          as="image"
          imagesrcset={heroPreload.srcSet?.attribute}
          imagesizes="100vw"
          type="image/webp"
          fetchpriority="high"
        />
      </Fragment>
    )
  }

  <!-- Full-bleed hero carousel of featured projects -->
  <HeroCarousel slides={heroSlides} />

  <!--
    Studio intro module — matches the presentational rhythm of the
    "Studio note" section below: small kicker + paragraph, no second
    page-level <h1>. (The <h1> already lives inside each carousel slide.)
  -->
  <section class="mx-auto max-w-3xl px-6 sm:px-8 pt-20 sm:pt-24 pb-12 text-center">
    <p
      class="text-xs uppercase tracking-[0.22em] text-mid-grey"
      data-reveal="up"
    >
      Solvang &middot; Santa Ynez Valley &middot; Central Coast
    </p>
    <p
      class="mt-6 text-xl sm:text-2xl text-near-black leading-snug"
      style="font-family: var(--font-display);"
      data-reveal="up"
      data-reveal-delay="120"
    >
      Moritz and Wade have
      DESIGNED, PLANNED, and PERMITTED
      people's DREAMS across Santa Barbara County and Santa Ynez Valley
      from small residential homes, to landmark commercial venues
    </p>
  </section>

  <!-- Studio note -->
  <section
    class="bg-near-black text-off-white py-20 sm:py-28"
    aria-labelledby="studio-heading"
  >
    <div class="mx-auto max-w-3xl px-6 sm:px-8">
      <p
        class="text-xs uppercase tracking-[0.22em] text-warm-grey"
        data-reveal="up"
      >
        The studio
      </p>
      <h2
        id="studio-heading"
        class="mt-4 text-3xl sm:text-4xl text-off-white"
        data-reveal="up"
        data-reveal-delay="120"
      >
        A dialogue, not a delivery.
      </h2>
      <p
        class="mt-6 text-lg leading-relaxed text-off-white/85"
        data-reveal="up"
        data-reveal-delay="240"
      >
        Great architecture begins with an exchange of ideas, a conversation
        that gives form to possibility. Whether you bring a fully formed vision
        or just a first spark, we work closely with you to shape spaces that
        honor the relationship between the constructed and the natural.
      </p>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="mx-auto max-w-7xl px-6 sm:px-8 py-20 sm:py-28">
    <div
      class="flex items-end justify-between gap-4 mb-12"
      data-reveal="up"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-mid-grey">
          Selected work
        </p>
        <h2 class="mt-3 text-2xl sm:text-3xl text-near-black">
          Recent projects
        </h2>
      </div>
      <a
        href="/portfolio"
        class="text-xs uppercase tracking-[0.16em] hover:text-terracotta transition-colors whitespace-nowrap"
      >
        See all →
      </a>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
      {
        featured.map((p, i) => (
          <li data-reveal="up" data-reveal-delay={i * 140}>
            <a
              href={`/portfolio/${p.id}`}
              class="group block focus:outline-none"
              aria-label={`View ${p.data.title}`}
            >
              <div class="aspect-[4/3] overflow-hidden bg-warm-grey/20">
                <Image
                  src={p.data.coverImage}
                  alt={`${p.data.title} — ${p.data.location}`}
                  widths={[400, 700, 1000]}
                  sizes="(min-width: 1024px) 380px, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  class="size-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                />
              </div>
              <div class="mt-5">
                <h3 class="text-lg font-semibold text-near-black group-hover:text-terracotta transition-colors">
                  {p.data.title}
                </h3>
                <p class="mt-1 text-[11px] uppercase tracking-[0.16em] text-mid-grey">
                  {p.data.location}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

</BaseLayout>
